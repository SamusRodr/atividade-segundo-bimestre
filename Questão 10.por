programa
{
	
	funcao inicio()
	{
		inteiro comprimento = 105
		inteiro largura = 68
		inteiro area

		escreva("O maraca possui	105 metros de comprimento e 68 metros de largura \n")

		area = comprimento * largura

		escreva ("A area do maracanã é de ", area, " metros e o dobro da área é ", area * 2 )

		
	}
}
